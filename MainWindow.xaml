<Window x:Class="ai_chatttt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ai_chatttt"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>


        <!-- 
            HOME GRID
            This grid serves as the main landing page  of the application.
            It contains a logo for AI , a welcome message to greet users,
            and a navigation button to proceed to the next section.
            Currently hidden by default.
        -->
        <Grid x:Name="home_grid" Visibility="Visible"
              >

            <!-- Logo -->
            <Image 
                Source="/logo.jpg" 
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
            <!-- welcome message-->
            <TextBlock
                Text="Welcome to Cyber Securiity ChatBot,click Proceed  button to continue"
                Height="20"
                Width="450"
                TextAlignment="Center"
                Margin="0,30,0,0"
                FontWeight="Bold"
                FontStyle="Italic"
                
                />

            <!-- button to continue-->
            <Button 
                Height="40"
                Width="300"
                Margin="0,200,0,0"
                Content="PROCEED"
                Click="proceed"
                FontSize="22"
                FontStyle="Italic"
                Foreground="white"
                Background="SkyBlue"
                
                />

        </Grid>

        <!-- 
            USERNAME GRID
            This grid is for prompting the user for username.
            It contains a logo for AI, a textbox for users to enter their name,
            and a submit button to save the username.
            Hidden .
        -->
        <Grid x:Name="username_grid" Visibility="Hidden">


            <!-- Logo -->
            <Image 
                Source="/logo.jpg" 
                Height="200"
                Width="280"
                Margin="0,10,400,0"
                   />
            <!-- Hint message-->
            <TextBlock
                Text="Enter username"
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="150,70,0,200"
                FontFamily="Arial Rounded MT Bold"
                />

            <!-- Enter/Prompt username-->
            <TextBox
                Height="40"
                Width="270"
                TextAlignment="Center"
                Margin="150,0,0,50"
                FontFamily="Arial Rounded MT Bold"
                x:Name="usernames_input"
                />

            <!-- error message-->
            <!-- error message-->
            <TextBlock
    x:Name="username_error"
    Text="please enter username to continue..."
    Height="20"
    Width="270"
    TextAlignment="Justify"
    Margin="150,50,0,0"
    Foreground="Red"
    FontFamily="Arial Rounded MT Bold"
    Visibility="Hidden"
    FontWeight="Bold"
/>

            <!-- button to submit name-->
               <Button 
               Height="40"
               Width="270"
               Margin="150,130,0,0"
               Content="submit username"
               Click="submit_name"
               FontSize="22"
               Foreground="white"
               Background="SkyBlue"
                />

        </Grid>

        <!-- 
            CHAT GRID
            This grid handles all messaging and conversation-related features of the application.
            It contains a ListView to display chat messages, a textbox for typing questions,
            and a submit button to send the question to the chat.
            Starting in a hidden state.
        -->
        <Grid x:Name="chat_grid" Visibility="Hidden">

            <!-- Welcome Title -->
            <TextBlock
        Text="Welcome to Cyber Security ChatBot"
        FontSize="28"
        FontWeight="Bold"
        Foreground="SkyBlue"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Margin="0,20,0,0"
        FontFamily="Segoe UI"/>

            <!-- Subtitle -->
            <TextBlock
        Text="Ask me anything about cyber security"
        FontSize="14"
        FontStyle="Italic"
        Foreground="Gray"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Margin="0,60,0,0"/>

            <!-- List view to show messages -->
            <ListView  
        x:Name="chats" 
        Height="250"
        Width="770"
        Margin="0,0,0,0"/>

            <!-- TextBox -->
            <TextBox
        x:Name="question"
        Height="50"
        Width="480"
        Margin="0,350,300,0"/>

            <!-- Send Button -->
            <Button
        Height="50"
        Width="280"
        Margin="490,350,0,0"
        Content="Send"
        Click="send"
        FontStyle="Italic"
        Foreground="White"
        Background="SkyBlue"
        FontWeight="Bold"/>

        </Grid>

    </Grid>
</Window>